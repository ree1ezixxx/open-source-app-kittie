{
  "name": "@kittie/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kittie-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --external:@modelcontextprotocol/sdk --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "check:packaged": "node ../../scripts/check-mcp-packaged.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@kittie/build-context": "workspace:*",
    "@kittie/intelligence": "workspace:*",
    "@kittie/reports": "workspace:*",
    "@kittie/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "esbuild": "^0.25.12"
  }
}