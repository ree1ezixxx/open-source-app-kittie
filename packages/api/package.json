{
  "name": "@kittie/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "ai:smoke": "tsx src/scripts/gemini-smoke.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@hono/node-server": "^1.14.4",
    "@kittie/core": "workspace:*",
    "@kittie/db": "workspace:*",
    "@kittie/ingest": "workspace:*",
    "@kittie/intelligence": "workspace:*",
    "@kittie/types": "workspace:*",
    "hono": "^4.7.11",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
