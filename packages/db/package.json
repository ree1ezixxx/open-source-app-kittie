{
  "name": "@kittie/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@kittie/intelligence": "workspace:*",
    "@kittie/types": "workspace:*",
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
