{
  "name": "@kittie/reports",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "import": "./src/browser.ts",
      "default": "./dist/browser.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kittie/core": "workspace:*",
    "@kittie/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
