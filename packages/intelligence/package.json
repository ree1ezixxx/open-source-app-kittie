    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@kittie/db": "workspace:*",
    "@kittie/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitest/ui": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
