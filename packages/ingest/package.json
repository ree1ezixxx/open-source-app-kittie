{
  "name": "@kittie/ingest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/jobs/seed.ts",
    "snapshot": "tsx src/jobs/snapshot.ts",
    "snapshot:bulk": "tsx src/jobs/snapshot-bulk.ts",
    "snapshot:due": "tsx src/jobs/snapshot-due.ts",
    "chart:capture": "tsx src/jobs/chart-capture.ts",
    "carry-forward": "tsx src/jobs/carry-forward.ts",
    "worker": "tsx src/jobs/snapshot-worker.ts",
    "discover:apple": "tsx src/jobs/apple-discover.ts",
    "score": "tsx src/jobs/score.ts",
    "keywords": "tsx src/jobs/keyword-sync.ts",
    "test": "vitest run",
    "retag": "tsx src/jobs/retag-reviews.ts",
    "seed-reviews": "tsx src/jobs/seed-reviews.ts"
  },
  "dependencies": {
    "@kittie/core": "workspace:*",
    "@kittie/db": "workspace:*",
    "@kittie/intelligence": "workspace:*",
    "@kittie/types": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "google-play-scraper": "^10.1.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
