{
  "name": "@kittie/ingest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/jobs/seed.ts",
    "snapshot": "tsx src/jobs/snapshot.ts",
    "reviews": "tsx src/jobs/review-sync.ts",
    "score": "tsx src/jobs/score.ts"
  },
  "dependencies": {
    "@kittie/core": "workspace:*",
    "@kittie/db": "workspace:*",
    "@kittie/types": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "google-play-scraper": "^10.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
