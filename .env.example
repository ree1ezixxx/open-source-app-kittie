# Database
DATABASE_URL=file:./data/kittie.db

# AI engine — free Gemini (gemini-2.5-flash), server-side in packages/api
GEMINI_API_KEY=your-gemini-api-key-here

# Ingest — review sync (optional tuning)
# REVIEW_SYNC_PER_APP=50
# REVIEW_SYNC_APP_LIMIT=0
# REVIEW_SYNC_GOOGLE_DELAY_MS=150

# Meta Ad Library (optional — public API, no key required for basic search)
# META_ACCESS_TOKEN=

# API server + web dev proxy
PORT=3008
VITE_API_ORIGIN=http://localhost:3008
